# Environment Configuration for Timetide
# Copy this file to .env and update with your values

# Database Configuration
# For local development with SQLite (default):
DATABASE_URL=sqlite:///./timetide.db

# For production with PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/timetide

# JWT Secret Key
# Generate a secure random key for production:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# Application Settings
APP_NAME=Timetide
APP_VERSION=1.0.0
DEBUG=True

# CORS Settings (if needed for frontend separation)
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
